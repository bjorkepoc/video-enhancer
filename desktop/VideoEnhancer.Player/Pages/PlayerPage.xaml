<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="VideoEnhancer_Player.Pages.PlayerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="16" ColumnSpacing="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="480" />
            <ColumnDefinition Width="360" />
        </Grid.ColumnDefinitions>

        <Grid RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <MediaPlayerElement
                x:Name="PlayerElement"
                AreTransportControlsEnabled="False"
                Stretch="Uniform" />

            <CommandBar Grid.Row="1" DefaultLabelPosition="Right" IsOpen="False">
                <AppBarButton Click="OpenVideo_Click" Label="Open">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="OpenFile" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton x:Name="PlayPauseButton" Click="PlayPause_Click" Label="Play">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Play" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton Click="FrameBack_Click" Label="Frame back">
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE76B;" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton Click="FrameForward_Click" Label="Frame forward">
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE76C;" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarSeparator />
                <AppBarToggleButton x:Name="SlowModeButton" Click="SlowMode_Click" Label="Step FPS">
                    <AppBarToggleButton.Icon>
                        <SymbolIcon Symbol="Clock" />
                    </AppBarToggleButton.Icon>
                </AppBarToggleButton>
                <AppBarElementContainer>
                    <ComboBox x:Name="StepFpsBox" Width="96" SelectedIndex="0">
                        <ComboBoxItem Content="1 FPS" Tag="1" />
                        <ComboBoxItem Content="2 FPS" Tag="2" />
                        <ComboBoxItem Content="5 FPS" Tag="5" />
                        <ComboBoxItem Content="10 FPS" Tag="10" />
                    </ComboBox>
                </AppBarElementContainer>
            </CommandBar>

            <Grid Grid.Row="2" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Slider
                    x:Name="TimelineSlider"
                    Minimum="0"
                    ValueChanged="TimelineSlider_ValueChanged" />
                <TextBlock
                    x:Name="TimeText"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Text="00:00 / 00:00" />
            </Grid>
        </Grid>

        <ScrollViewer Grid.Column="1">
            <StackPanel Spacing="14">
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Enhance" />

                <InfoBar
                    x:Name="StatusInfo"
                    IsOpen="False"
                    Severity="Informational" />

                <TextBlock Text="Input" />
                <TextBox x:Name="InputPathBox" IsReadOnly="True" PlaceholderText="Open a video first" />

                <TextBlock Text="Output" />
                <TextBox x:Name="OutputPathBox" PlaceholderText="Output .mp4 path" />

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Preset" />
                        <ComboBox x:Name="PresetBox" SelectedIndex="3">
                            <ComboBoxItem Content="fast" />
                            <ComboBoxItem Content="balanced" />
                            <ComboBoxItem Content="quality" />
                            <ComboBoxItem Content="ultra" />
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="6">
                        <TextBlock Text="Filter backend" />
                        <ComboBox x:Name="FilterBackendBox" SelectedIndex="1">
                            <ComboBoxItem Content="cpu" />
                            <ComboBoxItem Content="auto" />
                            <ComboBoxItem Content="cuda" />
                            <ComboBoxItem Content="opencl" />
                            <ComboBoxItem Content="vulkan" />
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Scale" />
                        <NumberBox x:Name="ScaleBox" Minimum="0.1" SmallChange="0.5" Value="2" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="6">
                        <TextBlock Text="FPS" />
                        <NumberBox x:Name="FpsBox" Minimum="1" SmallChange="1" Value="60" />
                    </StackPanel>
                </Grid>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <CheckBox x:Name="NoUpscaleBox" Content="No upscale" />
                    <CheckBox x:Name="NoInterpolateBox" Grid.Column="1" Content="No interpolation" />
                </Grid>

                <TextBlock Text="Video codec" />
                <ComboBox x:Name="CodecBox" SelectedIndex="0">
                    <ComboBoxItem Content="libx264" />
                    <ComboBoxItem Content="libx265" />
                    <ComboBoxItem Content="h264_nvenc" />
                    <ComboBoxItem Content="hevc_nvenc" />
                    <ComboBoxItem Content="av1_nvenc" />
                    <ComboBoxItem Content="h264_amf" />
                    <ComboBoxItem Content="hevc_amf" />
                    <ComboBoxItem Content="av1_amf" />
                    <ComboBoxItem Content="h264_qsv" />
                    <ComboBoxItem Content="hevc_qsv" />
                    <ComboBoxItem Content="av1_qsv" />
                </ComboBox>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Quality" />
                        <NumberBox x:Name="QualityBox" Minimum="0" Maximum="51" SmallChange="1" Value="16" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="6">
                        <TextBlock Text="Encoder preset" />
                        <TextBox x:Name="EncoderPresetBox" PlaceholderText="auto" />
                    </StackPanel>
                </Grid>

                <CheckBox x:Name="OverwriteBox" Content="Overwrite output" />

                <ProgressBar
                    x:Name="EnhanceProgress"
                    Minimum="0"
                    Maximum="100"
                    Value="0" />
                <TextBlock x:Name="ProgressText" Text="Idle" TextWrapping="Wrap" />

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <Button Click="DryRun_Click" Content="Dry run" />
                    <Button Grid.Column="1" Click="Enhance_Click" Content="Enhance" />
                    <Button Grid.Column="2" Click="Cancel_Click" Content="Cancel" />
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
